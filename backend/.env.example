# Supabase project URL (e.g., https://abcdefgh.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous/public key (found in Project Settings > API)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (found in Project Settings > API) - KEEP SECRET
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT secret for token signing (generate a strong random string)
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Internal API key for service-to-service calls
API_KEY=generate-a-strong-api-key-here

# Environment: development, staging, production
ENVIRONMENT=development

# Enable debug mode (true/false)
DEBUG=true

# Rate limit: requests per time window (e.g., 100/minute)
RATE_LIMIT=100/minute

# Server port
PORT=8000

# Server host
HOST=0.0.0.0
